{
  "name": "invoicer-functions",
  "description": "FacturaFácil — Firebase Cloud Functions API",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve:local": "npm run build && firebase emulators:start --only functions,firestore",
    "emulate": "firebase emulators:start --export-on-exit ./emulator-data --import ./emulator-data",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "deploy": "firebase deploy --only functions",
    "deploy:dev": "firebase use dev && npm run build && firebase deploy --only functions",
    "deploy:qa": "firebase use qa && npm run build && firebase deploy --only functions",
    "deploy:prod": "firebase use prod && npm run build && firebase deploy --only functions",
    "smoke:qa": "node -e \"fetch('https://us-central1-invoicer-qa.cloudfunctions.net/api/health').then(r=>r.json()).then(console.log).catch(console.error)\"",
    "smoke:prod": "node -e \"fetch('https://us-central1-invoicer-6a7c2.cloudfunctions.net/api/health').then(r=>r.json()).then(console.log).catch(console.error)\"",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "mongoose": "^9.3.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/",
      "\\._"
    ],
    "setupFiles": [
      "./tests/setup.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "private": true
}
